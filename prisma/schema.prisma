// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Course {
  id          String    @id @default(cuid())
  slug        String    @unique // "a1-new" | "a1-rep"
  name        String // "A1 New Batch"
  description String?
  startDate   String // "2026-06-01" — course start date
  daysOfWeek  String // "1,3,5" (Mon,Wed,Fri) — comma-separated day numbers
  startTime   String // "17:00" in IST
  endTime     String // "18:00" in IST
  capacity    Int // max students per slot
  isActive    Boolean   @default(true)
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Booking {
  id              String   @id @default(cuid())
  bookingId       String   @unique // "BOOK-20260505-001"
  customerName    String
  customerEmail   String
  customerPhone   String?
  courseId         String
  course          Course   @relation(fields: [courseId], references: [id])
  bookingDate     String // "2026-05-12" — the specific class date booked
  timeSlot        String // "17:00-18:00"
  notes           String?
  status          String   @default("confirmed") // confirmed | pending | cancelled
  calendarEventId String? // Google Calendar event ID
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([courseId, bookingDate])
  @@index([customerEmail])
}

model BookingLog {
  id        String   @id @default(cuid())
  action    String // "booking_created", "booking_failed", "email_sent", etc.
  bookingId String?
  details   String // JSON string with extra details
  createdAt DateTime @default(now())
}
